{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "crons": [
    {
      "path": "/api/cron-outreach",
      "schedule": "*/15 * * * 1-5"
    },
    {
      "path": "/api/cron-content-generator",
      "schedule": "0 10 * * *"
    }
  ]
}
